{
    "manifest_version": 3,
    "name": "Tongue: YouTube Live Translator",
    "version": "1.0",
    "permissions": [
        "tabCapture",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "http://localhost:8000/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}